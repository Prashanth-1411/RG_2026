{
    "version": 2,
    "framework": null,
    "builds": [
        {
            "src": "/api/*.php",
            "use": "vercel-php@0.6.2"
        }
    ],
    "routes": [
        {
            "src": "/api/ping",
            "dest": "/api/ping.php"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "cleanUrls": true
}
